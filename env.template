# Server
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://signal:password@localhost:5432/signal_clone
REDIS_URL=redis://:password@localhost:6379
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# TURN Server (Coturn)
TURN_SECRET=your_super_secret_turn_key_here
# TURN_HOST: PUBLIC IP or domain of your Coturn server (e.g. 1.2.3.4 or turn.yourdomain.com)
# This MUST be reachable from the internet — NOT your web server hostname.
# Without this, calls between users on different networks (cities/countries) will FAIL.
TURN_HOST=your_coturn_server_public_ip_or_domain
TURN_SERVER_URL=turns:turn.kurakani.app:5349

# Next.js public TURN vars (exposed to browser)
# NEXT_PUBLIC_TURN_HOST= same as TURN_HOST above (optional, API route sends it)
# NEXT_PUBLIC_METERED_API_KEY= get a free key from https://dashboard.metered.ca
# Without this, fallback TURN uses public demo credentials that are rate-limited and unreliable

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=signal-attachments
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin

# Push Notifications (Firebase / APNs)
FIREBASE_KEY={"type":"service_account"}
APN_KEY=-----BEGIN PRIVATE KEY-----...
APN_KEY_ID=ABCDEFGHIJ
APN_TEAM_ID=1234567890
APN_BUNDLE_ID=app.kurakani.mobile
